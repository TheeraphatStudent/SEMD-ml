REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=example
REDIS_DB=0

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=example
POSTGRES_PASSWORD=exmaple
