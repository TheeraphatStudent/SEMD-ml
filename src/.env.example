MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=malicious_url_detection

ENABLE_FEATURE_SELECTION=true
FEATURE_SELECTION_K=50
FEATURE_SELECTION_METHOD=auto

ENABLE_FEATURE_IMPORTANCE=true
